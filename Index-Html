            }
            #services .mb-12 > .flex::-webkit-scrollbar { display: none; }
            .capability-tab {
                flex-shrink: 0 !important; background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.05); padding: 10px 16px !important;
                border-radius: 8px; display: flex; align-items: center;
            }
            .capability-tab.active { background: rgba(234, 179, 8, 0.1); border-color: rgba(234, 179, 8, 0.3); }
            .capability-tab::after { display: none !important; }
            #gallery-grid { gap: 12px !important; }
            #gallery-grid .gallery-item .absolute.bottom-0 { padding: 14px 12px !important; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 50%, transparent 100%) !important; }
            #gallery-grid .gallery-item .absolute.bottom-0 span.inline-block { font-size: 8px !important; padding: 4px 6px !important; margin-bottom: 6px !important; letter-spacing: 0.1em !important; border-radius: 3px !important; }
