        .orb { position: absolute; border-radius: 50%; background: radial-gradient(circle, rgba(234, 179, 8, 0.18) 0%, transparent 70%); }
        .orb-1 { top: -5%; left: 5%; width: 650px; height: 650px; animation: orb-float 20s infinite alternate; }
        .orb-2 { bottom: -5%; right: 5%; width: 750px; height: 750px; animation: orb-float 25s infinite alternate-reverse; }
        @keyframes orb-float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(80px, 80px) scale(1.2); }
        }
        .bg-vignette { position: fixed; inset: 0; z-index: -1; background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.7) 100%); pointer-events: none; }
        .bg-grain { position: fixed; inset: 0; z-index: -1; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E"); opacity: 0.04; pointer-events: none; }

        /* --- UI ELEMENTS --- */
        .text-gold {
            background: linear-gradient(90deg, #A16207 0%, #D97706 25%, #FBBF24 50%, #D97706 75%, #A16207 100%);
            background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text; animation: text-shine 6s ease-in-out infinite alternate, text-glow-pulse 5s ease-in-out infinite;
        }
        .bg-gold-gradient { background: linear-gradient(135deg, #FDE047 0%, #EAB308 50%, #A16207 100%); }
        .perspective-2000 { perspective: 2000px; }
        
        @keyframes border-spin { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }
        .neon-glow-container { position: absolute; inset: -2px; z-index: 0; overflow: hidden; border-radius: 6px; }
        .neon-glow-line {
            position: absolute; top: 50%; left: 50%; width: 250%; height: 250%;
            background: conic-gradient(from 0deg, transparent 0%, transparent 80%, #EAB308 95%, #FDE047 100%);
            animation: border-spin 3s linear infinite; filter: blur(1.5px) drop-shadow(0 0 8px #EAB308);
        }
        .neon-glow-mask { position: absolute; inset: 2px; background: #0a0a0a; border-radius: 4px; z-index: 1; }

        .btn-premium-gold { position: relative; overflow: hidden; transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .btn-premium-gold::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent); transition: 0.5s;
        }
        .btn-premium-gold:hover::before { left: 100%; }
        .btn-premium-gold:hover { box-shadow: 0 0 50px rgba(234, 179, 8, 0.5); transform: translateY(-8px) scale(1.02); }

        .reveal-delay-1 { animation-delay: 0.15s; }
        .reveal-delay-2 { animation-delay: 0.35s; }
        .reveal-delay-3 { animation-delay: 0.55s; }
        .reveal-delay-4 { animation-delay: 0.75s; }
        .reveal-delay-5 { animation-delay: 0.95s; }
        .reveal-delay-6 { animation-delay: 1.15s; }

        #smart-nav { transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .nav-hidden { transform: translateY(-100%); }

        /* --- CAPABILITIES STYLES --- */
        .capability-tab {
            position: relative; padding: 10px 0; cursor: pointer; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            opacity: 0.8; color: #e5e5e5; font-weight: 500; display: flex; align-items: center;
        }
        .capability-tab .num { font-size: 0.7rem; margin-right: 8px; font-family: serif; opacity: 0.5; transition: all 0.5s; }
        .capability-tab:hover { opacity: 1; transform: translateY(-2px); color: #ffffff; }
        .capability-tab.active { opacity: 1; color: #EAB308; font-weight: 700; }
        .capability-tab.active .num { opacity: 1; color: #EAB308; }
        .capability-tab::after {
            content: ''; position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%) scaleX(0);
            width: 100%; height: 1px; background: linear-gradient(90deg, transparent, #EAB308, transparent);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .capability-tab.active::after { transform: translateX(-50%) scaleX(1); }
        
        .capability-pane { display: none; animation: paneReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .capability-pane.active { display: block; }
        @keyframes paneReveal {
            from { opacity: 0; transform: translateY(30px) scale(0.99); filter: blur(10px); }
            to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
        }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 2px; position: relative; overflow: hidden;
        }
        .glass-card::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle 600px at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(234, 179, 8, 0.07), transparent 40%);
            z-index: 0; opacity: 0; transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1); pointer-events: none;
        }
        .glass-card:hover::before { opacity: 1; }
        .glass-card > * { position: relative; z-index: 1; }

        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* --- FILTER GALLERY STYLES --- */
        .gallery-item { animation: fadeInScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .gallery-item img { transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1), filter 1.5s ease; }
        @keyframes fadeInScale { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
        .filter-btn { transition: all 0.3s ease; }
        .filter-btn.active { background-color: rgba(234, 179, 8, 0.15); border-color: rgba(234, 179, 8, 0.5); color: #FDE047; }

        /* --- GLOWING SECTION DIVIDER --- */
        .section-divider-glow {
            position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 50%; max-width: 500px; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(253, 224, 71, 0.9) 50%, transparent);
            box-shadow: 0 2px 10px rgba(234, 179, 8, 0.7), 0 10px 30px rgba(234, 179, 8, 0.3);
            z-index: 0; pointer-events: none; animation: lamp-glow 3.5s ease-in-out infinite alternate;
        }
        .section-divider-glow::after {
            content: ''; position: absolute; top: 1px; left: 50%; transform: translateX(-50%); width: 100%; height: 100px; 
            background: radial-gradient(ellipse at top, rgba(234, 179, 8, 0.15) 0%, transparent 70%); pointer-events: none;
        }
        @keyframes lamp-glow { 0% { opacity: 0.5; } 100% { opacity: 1; } }

        /* --- DYNAMIC SCROLL ANIMATIONS --- */
        .fade-in-up {
            opacity: 0; transform: translateY(40px) scale(0.98) translateZ(0); will-change: opacity, transform;
            transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .fade-in-up.is-visible { opacity: 1; transform: translateY(0) scale(1) translateZ(0); }
        .delay-100 { transition-delay: 100ms; }
        .delay-200 { transition-delay: 200ms; }

        /* --- RESPONSIVE MASKS --- */
        .hero-bg-mask {
            -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 40%, black 100%);
            mask-image: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 40%, black 100%);
        }
        @media (min-width: 1024px) {
            .hero-bg-mask {
                -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 35%, rgba(0,0,0,0.6) 70%, black 100%);
                mask-image: linear-gradient(to right, transparent 0%, transparent 35%, rgba(0,0,0,0.6) 70%, black 100%);
            }
        }
        .hologram-mask {
            -webkit-mask-image: radial-gradient(circle, black 30%, transparent 70%);
            mask-image: radial-gradient(circle, black 30%, transparent 70%);
        }

        /* --- ENHANCED MOBILE UI OPTIMIZATIONS --- */
        @media (max-width: 639px) {
