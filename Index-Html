            overflow-x: hidden;
            width: 100%;
            min-height: 100vh;
        }

        /* --- BACKGROUND SYSTEM --- */
        .bg-pattern {
            position: fixed; inset: 0; z-index: -4;
            background-image: radial-gradient(rgba(234, 179, 8, 0.22) 1.5px, transparent 1.5px);
            background-size: 40px 40px;
            mask-image: radial-gradient(circle at center, black 40%, transparent 90%);
            -webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 90%);
            pointer-events: none;
        }
        .bg-lines {
            position: fixed; inset: 0; z-index: -3; display: flex;
            justify-content: space-around; pointer-events: none; opacity: 0.18;
        }
        .bg-line {
            width: 1px; height: 100%; position: relative; overflow: hidden;
            background: linear-gradient(to bottom, transparent, rgba(234, 179, 8, 0.4), transparent);
        }
        .bg-line::after {
